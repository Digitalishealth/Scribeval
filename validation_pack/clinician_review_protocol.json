{
  "schema_version": "1.0.0",
  "protocol_id": "scribeval_independent_clinician_review_v1",
  "status": "ready_for_independent_review",
  "benchmark_unit": "whole transcript -> final note quality score",
  "review_materials": {
    "case_packets": "reviewer_packets/",
    "worksheet_template": "reviewer_worksheet.csv",
    "reviewer_registry_template": "reviewer_registry_template.csv"
  },
  "reviewer_identity_policy": {
    "store_pseudonymous_reviewer_id_only": true,
    "forbidden_public_fields": [
      "name",
      "email",
      "phone",
      "provider_number",
      "registration_number"
    ]
  },
  "minimum_independent_review_requirements": {
    "reviewers_per_case": 2,
    "reviewers_per_case_submission": 2,
    "eligible_registration_status": "current",
    "minimum_years_post_registration": 1,
    "required_training_completed": true,
    "required_dimensions": [
      "omission",
      "hallucination",
      "medicolegal",
      "ahpra",
      "pdqi9",
      "qnote"
    ],
    "optional_dimensions": [
      "medication_terminology"
    ],
    "allowed_review_roles": [
      "primary_reviewer",
      "secondary_reviewer",
      "adjudicator"
    ],
    "conflict_of_interest": "none"
  },
  "assignment_builder_command": "python scripts/build_reviewer_assignments.py --reviewer-registry <reviewer_registry.csv> --output-dir <reviewer_assignments_dir>",
  "readiness_audit_command": "python scripts/audit_clinician_review_readiness.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --output-json <readiness_report.json> --output-md <readiness_report.md> --fail-on-not-ready",
  "judge_score_export_command": "python scripts/export_validation_judge_scores.py --output <scribeval_scores.json> --dimensions omission,hallucination,medicolegal,ahpra,pdqi9,qnote",
  "reviewer_reliability_command": "python scripts/summarize_reviewer_reliability.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --output-json <reviewer_reliability.json> --output-md <reviewer_reliability.md> --fail-on-not-ready",
  "consensus_rating_command": "python scripts/build_consensus_validation_ratings.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --judge-scores <scribeval_scores.json> --output <consensus_calibration_pairs.json> --output-summary-json <consensus_summary.json> --output-summary-md <consensus_summary.md>",
  "evidence_import_command": "python scripts/import_validation_ratings.py --worksheet <filled_worksheet.csv> --judge-scores <scribeval_scores.json> --reviewer-registry <reviewer_registry.csv> --require-qualified-reviewers --output <calibration_pairs.json>",
  "evidence_bundle_command": "python scripts/build_validation_evidence_bundle.py --run-id <review_run_id> --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --judge-scores <scribeval_scores.json> --output-dir validation_pack/evidence_runs",
  "clinical_validation_claim": "Do not claim independent clinical validation until the synthetic worksheet is replaced by qualified clinician ratings imported with reviewer provenance."
}
