{
  "schema_version": "1.0.0",
  "protocol_id": "scribeval_independent_clinician_review_v1",
  "status": "ready_for_independent_review",
  "benchmark_unit": "whole transcript -> final note quality score",
  "review_materials": {
    "case_packets": "reviewer_packets/",
    "worksheet_template": "reviewer_worksheet.csv",
    "reviewer_registry_template": "reviewer_registry_template.csv"
  },
  "reviewer_identity_policy": {
    "store_pseudonymous_reviewer_id_only": true,
    "forbidden_public_fields": [
      "name",
      "email",
      "phone",
      "provider_number",
      "registration_number"
    ]
  },
  "minimum_independent_review_requirements": {
    "reviewers_per_case": 2,
    "reviewers_per_case_submission": 2,
    "eligible_registration_status": "current",
    "minimum_years_post_registration": 1,
    "required_training_completed": true,
    "required_overall_rating": true,
    "required_dimensions": [
      "omission",
      "hallucination",
      "medicolegal",
      "ahpra",
      "pdqi9",
      "qnote"
    ],
    "optional_dimensions": [
      "medication_terminology"
    ],
    "allowed_review_roles": [
      "primary_reviewer",
      "secondary_reviewer",
      "adjudicator"
    ],
    "conflict_of_interest": "none"
  },
  "validation_claim_thresholds": {
    "required_evidence_status": "independent_clinician_review",
    "minimum_case_count": 20,
    "minimum_submission_count": 100,
    "minimum_qualified_reviewers": 2,
    "maximum_consensus_adjudication_required_count": 0,
    "minimum_reviewer_reliability_weighted_kappa": 0.6,
    "minimum_consensus_weighted_kappa": 0.6,
    "required_strata": [
      "specialty",
      "note_source",
      "prompt_strategy",
      "failure_mode"
    ]
  },
  "assignment_builder_command": "python scripts/build_reviewer_assignments.py --reviewer-registry <reviewer_registry.csv> --output-dir <reviewer_assignments_dir>",
  "readiness_audit_command": "python scripts/audit_clinician_review_readiness.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --output-json <readiness_report.json> --output-md <readiness_report.md> --fail-on-not-ready",
  "review_run_status_command": "python scripts/summarize_validation_review_run.py --reviewer-registry <reviewer_registry.csv> --assignments-dir <reviewer_assignments_dir> --worksheet <filled_worksheet.csv> --judge-scores <scribeval_scores.json> --output-json <review_run_status.json> --output-md <review_run_status.md> --fail-on-not-ready",
  "judge_score_export_command": "python scripts/export_validation_judge_scores.py --output <scribeval_scores.json> --dimensions omission,hallucination,medicolegal,ahpra,pdqi9,qnote",
  "reviewer_reliability_command": "python scripts/summarize_reviewer_reliability.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --output-json <reviewer_reliability.json> --output-md <reviewer_reliability.md> --fail-on-not-ready",
  "consensus_rating_command": "python scripts/build_consensus_validation_ratings.py --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --judge-scores <scribeval_scores.json> --output <consensus_calibration_pairs.json> --output-summary-json <consensus_summary.json> --output-summary-md <consensus_summary.md>",
  "adjudication_packet_command": "python scripts/build_adjudication_packets.py --consensus-pairs <consensus_calibration_pairs.json> --output-dir <adjudication_packets_dir>",
  "adjudication_import_command": "python scripts/import_adjudication_decisions.py --consensus-pairs <consensus_calibration_pairs.json> --adjudication-worksheet <filled_adjudication_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --adjudicator-id <adjudicator_reviewer_id> --require-qualified-adjudicator --output <adjudicated_consensus_calibration_pairs.json> --output-summary-json <adjudicated_consensus_summary.json> --output-summary-md <adjudicated_consensus_summary.md>",
  "validation_claim_readiness_command": "python scripts/assess_validation_claim_readiness.py --evidence-manifest <evidence_manifest.json> --output-json <validation_claim_readiness.json> --output-md <validation_claim_readiness.md> --fail-on-not-ready",
  "evidence_import_command": "python scripts/import_validation_ratings.py --worksheet <filled_worksheet.csv> --judge-scores <scribeval_scores.json> --reviewer-registry <reviewer_registry.csv> --require-qualified-reviewers --output <calibration_pairs.json>",
  "evidence_bundle_command": "python scripts/build_validation_evidence_bundle.py --run-id <review_run_id> --worksheet <filled_worksheet.csv> --reviewer-registry <reviewer_registry.csv> --judge-scores <scribeval_scores.json> --adjudicated-consensus-pairs <adjudicated_consensus_calibration_pairs.json> --output-dir validation_pack/evidence_runs",
  "evidence_run_index_command": "python scripts/index_validation_evidence_runs.py --evidence-runs validation_pack/evidence_runs --output-json validation_pack/evidence_runs/index.json --output-md validation_pack/evidence_runs/index.md",
  "clinical_validation_claim": "Do not claim independent clinical validation until the synthetic worksheet is replaced by qualified clinician ratings imported with reviewer provenance."
}
